<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">


<suite name="My Test Suite">
<!-- To run all the test cases parallaly we add parallel="test" attribute at suite level -->
<!-- To run no of test cases at one time => thread-count="2" => 2 test cases will be run at a time -->
<!-- <suite name="My Test Suite" parallel="tests" thread-count="5"> -->
  <listeners>
  	<listener class-name="TestNGPackage.Listeners"></listener>
  </listeners>

  <!-- This is first test method folder which has name='Introduction' -->
  <test name="Introduction">
  
    <classes>
      <class name="TestNGPackage.IntroductionTestNG">  <!-- Class name should be followed by its parent package name -->
		      <methods>
		      		<exclude name="testMethod3"/>
		      </methods>
	  </class>
    </classes>
    </test>
    
    <!-- This is another test method folder which has name='Loan Department' -->
    <test name="Loan Department">
    <!-- <test name="Loan Department" parallel="classes" thread-count="3"> --> <!-- This will run all the class test method parallel with 3 at a time -->
    <classes>
      <class name="TestNGPackage.Day1">
	      	  <methods>
	      			<exclude name="BikeLoan"/>
	      			<include name="MobileLoan"/>
	      	  </methods>
      </class>	
      
      <class name="TestNGPackage.Day2">
      </class>
    </classes>
    </test>
    
    
    <test name="Company">
    <classes>
      <class name="TestNGPackage.Day3">
		      <methods>
		      		<include name="Medi.*"/>
		      		<exclude name="Study.*"/>
		      		<include name="Dassault"/>
		      		<include name="RTSM"/>
		      		<include name="Phoenix"/>
		      		<include name="QA"/>
		      	</methods>
      </class>
    </classes>
  </test> <!-- Test -->
  
  
</suite> <!-- Suite -->
